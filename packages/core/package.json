{
  "name": "@graph-os/core",
  "version": "1.0.0",
  "description": "Core interfaces, types, and schemas for Graph-OS platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schemas/cartridge.schema.json": "./src/schemas/cartridge.schema.json",
    "./schemas/signal-registry.schema.json": "./src/schemas/signal-registry.schema.json",
    "./schemas/composite-registry.schema.json": "./src/schemas/composite-registry.schema.json"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graph-os",
    "node-based",
    "signal-driven",
    "architecture",
    "core"
  ],
  "author": "Graph-OS Team",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/graph-os/graph-os.git",
    "directory": "packages/core"
  }
}
