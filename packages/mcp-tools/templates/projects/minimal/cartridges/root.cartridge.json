{
    "version": "1.0.0",
    "name": "{{projectName}}",
    "description": "{{description}}",
    "inputs": [],
    "outputs": [],
    "nodes": [
        {
            "id": "input",
            "type": "control.input",
            "description": "User input handler",
            "config": {
                "prompt": "Enter input: ",
                "outputSignalType": "INPUT.SUBMITTED"
            }
        },
        {
            "id": "transform",
            "type": "logic.transform",
            "description": "Transform input",
            "config": {
                "outputSignalType": "DATA.TRANSFORMED",
                "rules": [
                    {
                        "from": "value",
                        "to": "transformedValue",
                        "transform": "uppercase"
                    }
                ]
            }
        },
        {
            "id": "display",
            "type": "control.display",
            "description": "Display output",
            "config": {
                "format": "json",
                "showTimestamp": true
            }
        }
    ],
    "wires": [
        {
            "from": "input",
            "to": "transform",
            "signalType": "INPUT.SUBMITTED"
        },
        {
            "from": "transform",
            "to": "display",
            "signalType": "DATA.TRANSFORMED"
        }
    ]
}