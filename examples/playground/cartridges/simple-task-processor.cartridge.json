{
  "version": "1.0.0",
  "name": "simple-task-processor",
  "description": "A simple task processing cartridge with validation and transformation",
  "inputs": [],
  "outputs": [],
  "nodes": [
    {
      "id": "task-input",
      "type": "control.input",
      "description": "Accept new task creation requests",
      "config": {
        "prompt": "Enter task description: ",
        "outputSignalType": "TASK.CREATE",
        "fieldName": "description"
      }
    },
    {
      "id": "task-validator",
      "type": "logic.validate",
      "description": "Validate task data structure",
      "config": {
        "schema": {
          "type": "object",
          "required": [
            "description"
          ],
          "properties": {
            "description": {
              "type": "string",
              "minLength": 3
            }
          }
        },
        "successSignalType": "TASK.VALID",
        "failureSignalType": "TASK.INVALID"
      }
    },
    {
      "id": "task-transform",
      "type": "logic.transform",
      "description": "Enrich task with metadata",
      "config": {
        "outputSignalType": "TASK.ENRICHED",
        "rules": [
          {
            "from": "description",
            "to": "title",
            "transform": "trim"
          }
        ],
        "includeUnmatched": false
      }
    },
    {
      "id": "task-display",
      "type": "control.display",
      "description": "Display processed tasks",
      "config": {
        "format": "json",
        "prefix": "✅ TASK PROCESSED",
        "showTimestamp": true
      }
    },
    {
      "id": "error-display",
      "type": "control.display",
      "description": "Display validation errors",
      "config": {
        "format": "json",
        "prefix": "❌ ERROR",
        "showTimestamp": true
      }
    }
  ],
  "wires": [
    {
      "from": "task-input",
      "to": "task-validator",
      "signalType": "TASK.CREATE"
    },
    {
      "from": "task-validator",
      "to": "task-transform",
      "signalType": "TASK.VALID"
    },
    {
      "from": "task-validator",
      "to": "error-display",
      "signalType": "TASK.INVALID"
    },
    {
      "from": "task-transform",
      "to": "task-display",
      "signalType": "TASK.ENRICHED"
    }
  ]
}