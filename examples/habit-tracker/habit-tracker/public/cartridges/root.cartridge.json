{
  "version": "1.0.0",
  "name": "habit-tracker",
  "description": "Habit tracker application with React + Graph-OS backend using signal-first architecture",
  "nodes": [
    {
      "id": "habit-create-input",
      "type": "control.input",
      "description": "Receive HABIT.CREATE signals from React",
      "config": {
        "inputSignalType": "HABIT.CREATE"
      }
    },
    {
      "id": "habit-validator",
      "type": "logic.validate",
      "description": "Validate habit data before saving",
      "config": {
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "frequency": {
              "type": "string",
              "enum": [
                "daily",
                "weekly"
              ]
            }
          },
          "required": [
            "name",
            "frequency"
          ]
        },
        "successSignalType": "HABIT.VALID",
        "failureSignalType": "HABIT.INVALID"
      }
    },
    {
      "id": "habit-transformer",
      "type": "logic.transform",
      "description": "Add habit to storage array",
      "config": {
        "outputSignalType": "HABIT.SAVED",
        "rules": [
          {
            "from": "originalPayload",
            "to": "habit"
          }
        ]
      }
    },
    {
      "id": "habit-storage",
      "type": "infra.storage.local",
      "description": "Save/load habits to local storage",
      "config": {
        "storageKey": "habits"
      }
    },
    {
      "id": "habit-complete-input",
      "type": "control.input",
      "description": "Receive HABIT.COMPLETE signals from React",
      "config": {
        "inputSignalType": "HABIT.COMPLETE"
      }
    },
    {
      "id": "habit-delete-input",
      "type": "control.input",
      "description": "Receive HABIT.DELETE signals from React",
      "config": {
        "inputSignalType": "HABIT.DELETE"
      }
    },
    {
      "id": "habit-load-input",
      "type": "control.input",
      "description": "Receive HABIT.LOAD signals from React",
      "config": {
        "inputSignalType": "HABIT.LOAD"
      }
    },
    {
      "id": "display",
      "type": "control.display",
      "description": "Display signals for debugging",
      "config": {
        "format": "json",
        "showTimestamp": true
      }
    }
  ],
  "wires": [
    {
      "from": "habit-create-input",
      "to": "habit-validator",
      "signalType": "HABIT.CREATE"
    },
    {
      "from": "habit-validator",
      "to": "habit-transformer",
      "signalType": "HABIT.VALID"
    },
    {
      "from": "habit-transformer",
      "to": "habit-storage",
      "signalType": "HABIT.SAVED"
    },
    {
      "from": "habit-validator",
      "to": "display",
      "signalType": "HABIT.INVALID"
    },
    {
      "from": "habit-complete-input",
      "to": "habit-storage",
      "signalType": "HABIT.COMPLETE"
    },
    {
      "from": "habit-delete-input",
      "to": "habit-storage",
      "signalType": "HABIT.DELETE"
    },
    {
      "from": "habit-load-input",
      "to": "habit-storage",
      "signalType": "HABIT.LOAD"
    },
    {
      "from": "habit-storage",
      "to": "display",
      "signalType": "HABIT.SAVED"
    },
    {
      "from": "habit-storage",
      "to": "display",
      "signalType": "HABIT.LOADED"
    },
    {
      "from": "habit-storage",
      "to": "display",
      "signalType": "HABIT.COMPLETED"
    },
    {
      "from": "habit-storage",
      "to": "display",
      "signalType": "HABIT.DELETED"
    }
  ],
  "inputs": [],
  "outputs": []
}
