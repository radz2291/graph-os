{
  "version": "1.0.0",
  "name": "habit-tracker",
  "description": "Habit tracker application with React + Graph-OS backend using signal-first architecture",
  "inputs": [],
  "outputs": [],
  "nodes": [
    {
      "id": "habit-validator",
      "type": "logic.validate",
      "description": "Validate habit data before saving",
      "config": {
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "frequency": {
              "type": "string",
              "enum": [
                "daily",
                "weekly"
              ]
            }
          },
          "required": [
            "name",
            "frequency"
          ]
        },
        "successSignalType": "HABIT.VALID",
        "failureSignalType": "HABIT.INVALID"
      }
    },
    {
      "id": "habit-transformer",
      "type": "custom.habit-transformer",
      "description": "Transform habit data by adding id, createdAt, and initializing completions array",
      "config": {
        "outputSignalType": "HABIT.TRANSFORMED"
      }
    },
    {
      "id": "habit-storage",
      "type": "infra.storage.local",
      "description": "Save habits to local storage",
      "config": {
        "key": "habits",
        "outputSignalType": "HABIT.SAVED"
      }
    },
    {
      "id": "display",
      "type": "control.display",
      "description": "Display habits for debugging",
      "config": {
        "format": "json",
        "showTimestamp": true
      }
    }
  ],
  "wires": [
    {
      "from": "habit-validator",
      "to": "habit-transformer",
      "signalType": "HABIT.VALID"
    },
    {
      "from": "habit-transformer",
      "to": "habit-storage",
      "signalType": "HABIT.TRANSFORMED"
    },
    {
      "from": "habit-storage",
      "to": "display",
      "signalType": "HABIT.SAVED"
    },
    {
      "from": "habit-validator",
      "to": "display",
      "signalType": "HABIT.INVALID"
    }
  ]
}
